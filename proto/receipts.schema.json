{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/genesis-ssmp/genesis/proto/receipts.schema.json",
  "title": "Verification Receipt",
  "description": "Proof that a task was executed and verified. Enables deterministic replay.",
  "type": "object",
  "required": ["mission_id", "env_hash", "command_hash", "stdout_hash", "exit_code", "timestamp"],
  "properties": {
    "mission_id": {
      "type": "string",
      "description": "Mission this receipt belongs to."
    },
    "env_hash": {
      "type": "string",
      "description": "Hash of the execution environment (toolchain versions, OS, etc.)."
    },
    "command_hash": {
      "type": "string",
      "description": "Hash of the command or AA bytecode that was executed."
    },
    "stdout_hash": {
      "type": "string",
      "description": "Hash of the captured stdout."
    },
    "exit_code": {
      "type": "integer",
      "description": "Process exit code (0 = success)."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of receipt creation."
    }
  },
  "additionalProperties": false
}
